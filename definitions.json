{
    "vhosts": [
      { "name": "project_home" }
    ],
    "users": [
      {
        "name": "guest",
        "password": "guest",
        "tags": "administrator"
      }
    ],
    "permissions": [
      {
        "user": "guest",
        "vhost": "project_home",
        "configure": ".*",
        "write": ".*",
        "read": ".*"
      }
    ],
    "exchanges": [
      {
        "name": "my_exchange",
        "vhost": "project_home",
        "type": "direct",
        "durable": true,
        "auto_delete": false,
        "internal": false,
        "arguments": {}
      }
    ],
    "queues": [
      {
        "name": "my_queue",
        "vhost": "project_home",
        "durable": true,
        "auto_delete": false,
        "arguments": {}
      }
    ],
    "bindings": [
      {
        "source": "my_exchange",
        "vhost": "project_home",
        "destination": "my_queue",
        "destination_type": "queue",
        "routing_key": "my_routing_key",
        "arguments": {}
      }
    ]
  }
  